@page
@model PeopleWatcher.Web.Pages.IndexModel
@{
    ViewData["Title"] = "PeopleWatcher";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/people-watcher.css" />
</head>
<body>
    <div id="header">
        <h1>👥 PeopleWatcher</h1>
        <div class="controls">
            <button id="respawnBtn">↺ Respawn</button>
            <button id="pauseBtn" class="secondary">⏸ Pause</button>
        </div>
        <div id="stats"></div>
    </div>

    <div id="world">
        <svg id="connections"></svg>
    </div>

    <div id="tooltip"></div>

    <script src="~/js/people-watcher.js"></script>
</body>
</html>
