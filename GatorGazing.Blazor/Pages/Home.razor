@page "/"
@inject IJSRuntime JS
@inject GatorGazing.SK.Agents.GatorAgentService AgentService
@inject IConfiguration Configuration
@implements IAsyncDisposable

<PageTitle>Swamp of Salem</PageTitle>

<div id="header">
    <h1>🐊 Swamp of Salem</h1>
    <div class="controls">
        <button id="respawnBtn">↺ Respawn</button>
        <button id="pauseBtn" class="secondary">⏸ Pause</button>
        <button id="dialogModeBtn" class="secondary" title="Toggle between AI Agent dialog and local JS dialog">🤖 AI</button>
    </div>
    <div id="stats"></div>
    <div id="phase-label" class="phase-label"></div>
</div>

<div id="world">
    <svg id="connections"></svg>
    <div id="night-overlay"></div>
    <div id="vote-tally" style="display:none"></div>
    <div id="game-over-overlay" style="display:none">
        <div class="go-card">
            <div class="go-title"></div>
            <div class="go-body"></div>
            <button id="goRestartBtn">↺ Play Again</button>
        </div>
    </div>
    <aside id="person-panel" class="person-panel" style="display:none">
        <button class="panel-close" id="panelCloseBtn" title="Close">✕</button>
        <div id="person-panel-content"></div>
    </aside>
</div>

@code {
    private IJSObjectReference? _module;
    private DotNetObjectReference<GatorGazing.Blazor.Interop.AgentInterop>? _interopRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Create the interop bridge and pass it to JS so the simulation can call agent methods
            var interop = new GatorGazing.Blazor.Interop.AgentInterop(AgentService);
            _interopRef = DotNetObjectReference.Create(interop);

            var dialogSource = Configuration["DialogSource"] ?? "AI";

            // Inject game constants into JS before module import so gameConfig.js can read them
            var configJson = GatorGazing.AppLogic.Services.GameConfigProvider.GetConfigJson();
            await JS.InvokeVoidAsync("eval", $"window.GameConfig = {configJson};");

            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/main.js");
            await _module.InvokeVoidAsync("initSimulation", _interopRef, dialogSource);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
            await _module.DisposeAsync();
        _interopRef?.Dispose();
    }
}
